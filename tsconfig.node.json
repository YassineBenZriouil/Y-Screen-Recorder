{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "types": ["node"],
        "outDir": "out"
    },
    "include": [
        "electron.vite.config.ts",
        "src/main/**/*.ts",
        "src/preload/**/*.ts"
    ]
}
